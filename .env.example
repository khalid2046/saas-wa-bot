# Copy this file to .env and fill in your values
# Place this file in: artifacts/api-server/.env

# PostgreSQL connection string (Render provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/wabotplatform

# JWT secret for signing login tokens (use a long random string)
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# CDK API credentials
CDK_API_BASE=https://keys.ovh/api/v1
CDK_API_KEY=your_cdk_api_key_here

# Server port (Render sets this automatically)
PORT=3000
